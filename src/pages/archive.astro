---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Reveal from "../components/Reveal.astro";
import { formatDateLong } from "../lib/dates";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const grouped = new Map<number, typeof posts>();
for (const p of posts) {
  const y = p.data.date.getUTCFullYear();
  if (!grouped.has(y)) grouped.set(y, [] as typeof posts);
  grouped.get(y)!.push(p);
}
const years = Array.from(grouped.keys()).sort((a, b) => b - a);
---

<Base
  title="Archivo"
  description="Lista cronológica de todos los artículos publicados en rauljcamacho.online."
  activeNav="archive"
>
  <main class="about-wrap">
    <Reveal>
      <span class="eyebrow">Archivo</span>
    </Reveal>
    <Reveal delay={60}>
      <h1>Todos los artículos.</h1>
    </Reveal>
    <Reveal delay={120}>
      <div class="about-body">
        {
          years.map((y) => (
            <section style="margin-top: 40px;">
              <h2 style="font-size: 28px; margin-bottom: 16px;">{y}</h2>
              <ul style="list-style: none; padding: 0; margin: 0;">
                {grouped.get(y)!.map((p) => (
                  <li style="padding: 12px 0; border-bottom: 1px solid var(--line);">
                    <a
                      href={`/posts/${p.id}`}
                      style="display: flex; justify-content: space-between; gap: 16px; align-items: baseline;"
                    >
                      <span style="font-family: var(--serif); font-size: 18px; color: var(--ink);">
                        {p.data.title}
                      </span>
                      <span style="font-size: 13px; color: var(--muted); white-space: nowrap;">
                        {formatDateLong(p.data.date)}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </Reveal>
  </main>
</Base>
