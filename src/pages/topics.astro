---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Reveal from "../components/Reveal.astro";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const tags = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1]);
---

<Base
  title="Temas"
  description="Explora artículos por tema: IA, agentes, infraestructura, UX, desarrollo y más."
  activeNav="topics"
>
  <main class="about-wrap">
    <Reveal>
      <span class="eyebrow">Temas</span>
    </Reveal>
    <Reveal delay={60}>
      <h1>Explora por tema.</h1>
    </Reveal>
    <Reveal delay={120}>
      <div class="about-body">
        <p>Etiquetas que aparecen en el blog, ordenadas por frecuencia.</p>
        <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px;">
          {
            tags.map(([tag, count]) => (
              <span class="pill">
                {tag} · {count}
              </span>
            ))
          }
        </div>
      </div>
    </Reveal>
  </main>
</Base>
