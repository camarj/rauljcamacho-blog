---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  type?: "website" | "article";
  publishedTime?: string;
  tags?: string[];
  author?: string;
  activeNav?: "home" | "topics" | "about" | "archive" | null;
}

const {
  title,
  description,
  image,
  canonical,
  type = "website",
  publishedTime,
  tags,
  author,
  activeNav = "home",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="rauljcamacho.online"
      href="/rss.xml"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <SEO
      title={title}
      description={description}
      image={image}
      canonical={canonical}
      type={type}
      publishedTime={publishedTime}
      tags={tags}
      author={author}
    />

    <script is:inline>
      // Theme: respetar preferencia guardada antes de pintar para evitar flash
      (function () {
        try {
          const saved = localStorage.getItem("theme");
          if (saved === "dark" || saved === "light") {
            document.documentElement.setAttribute("data-theme", saved);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <div id="root">
      <span class="side-deco left" aria-hidden="true"></span>
      <span class="side-deco right" aria-hidden="true"></span>

      <Header activeNav={activeNav} />

      <slot />

      <Footer />
    </div>

    <!-- SVG filter definitions (loaded once, used everywhere) -->
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <defs>
        <filter
          id="duotone-navy"
          x="0%"
          y="0%"
          width="100%"
          height="100%"
          color-interpolation-filters="sRGB"
        >
          <feColorMatrix
            type="matrix"
            values="0.33 0.33 0.33 0 0
                    0.33 0.33 0.33 0 0
                    0.33 0.33 0.33 0 0
                    0    0    0    1 0"
          />
          <feComponentTransfer>
            <feFuncR tableValues="0.082 0.910" type="table" />
            <feFuncG tableValues="0.137 0.878" type="table" />
            <feFuncB tableValues="0.278 0.823" type="table" />
          </feComponentTransfer>
        </filter>
      </defs>
    </svg>

    <!-- Reveal-on-scroll: identical IntersectionObserver behavior as the React version -->
    <script is:inline>
      (function () {
        const reveals = document.querySelectorAll("[data-reveal]");
        if (!reveals.length) return;
        const obs = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const el = entry.target;
                const delay = parseInt(el.getAttribute("data-reveal-delay") || "0", 10);
                setTimeout(() => el.classList.add("in"), delay);
                observer.unobserve(el);
              }
            });
          },
          { threshold: 0.08, rootMargin: "0px 0px -40px 0px" }
        );
        reveals.forEach((el) => obs.observe(el));
      })();
    </script>
  </body>
</html>
